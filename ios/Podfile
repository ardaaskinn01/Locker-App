# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # FIX: Remove unsupported '-GCC_WARN_INHIBIT_ALL_WARNINGS' flag from BoringSSL-GRPC
    # This flag gets passed as '-G' to the compiler which is unsupported on arm64-apple-ios
    # and causes build failures on Xcode 15/16 with newer LLVM versions.
    if target.name == 'BoringSSL-GRPC'
      target.source_build_phase.files.each do |file|
        if file.settings && file.settings['COMPILER_FLAGS']
          flags = file.settings['COMPILER_FLAGS'].split
          flags.reject! { |flag| flag == '-GCC_WARN_INHIBIT_ALL_WARNINGS' }
          file.settings['COMPILER_FLAGS'] = flags.join(' ')
        end
      end
    end

    # Ensure all targets have the correct minimum iOS deployment target
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end

  # FIX: Patch gRPC-Core's basic_seq.h template issue for Xcode 16 compatibility
  # Using sandbox root for absolute reliability
  grpc_file_path = File.join(installer.sandbox.root, "gRPC-Core/src/core/lib/promise/detail/basic_seq.h")
  if File.exist?(grpc_file_path)
    puts "gRPC-Core basic_seq.h found. Checking for template issue..."
    file_content = File.read(grpc_file_path)
    problematic_line = 'Traits::template CallSeqFactory(f_, *cur_, std::move(arg))'
    correct_line = 'Traits::template CallSeqFactory<>(f_, *cur_, std::move(arg))'
    if file_content.include?(problematic_line)
      puts "Patching gRPC-Core basic_seq.h for Xcode 16 compliance..."
      file_content.gsub!(problematic_line, correct_line)
      File.open(grpc_file_path, "w") { |file| file.puts file_content }
      puts "gRPC-Core basic_seq.h patched successfully."
    else
      puts "gRPC-Core basic_seq.h already patched or clean."
    end
  else
    puts "Warning: gRPC-Core basic_seq.h not found at #{grpc_file_path}."
  end
end
